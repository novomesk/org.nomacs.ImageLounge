{
    "app-id": "org.nomacs.ImageLounge",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--socket=fallback-x11",
        "--socket=wayland",
        "--socket=pulseaudio",
        "--filesystem=home",
        "--filesystem=/media",
        "--filesystem=/run/media"
    ],
    "command": "nomacs",
    "cleanup": [
        "/include",
        "/lib/pkgconfig",
        "/share/aclocal",
        "/share/man",
        "*.la",
        "*.a"
    ],
    "modules": [
        {
            "name": "exiv2",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_BUILD_TYPE=RelWithDebInfo",
                "-DEXIV2_BUILD_EXIV2_COMMAND=OFF",
                "-DEXIV2_ENABLE_INIH=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/Exiv2/exiv2/archive/refs/tags/v0.28.8.tar.gz",
                    "sha512": "e322438b565fe373e65baceeb4fd5173f538063b12b3d5a93d6e707da5020c818b1b9cc116f7bf0709635aa72b941dacb7a2bcfe6d946e2eaf7d9e55736dec5b"
                }
            ]
        },
        {
            "name": "opencv",
            "buildsystem": "cmake-ninja",
            "builddir": true,
            "config-opts": [
                "-DWITH_FFMPEG=OFF",
                "-DBUILD_opencv_apps=OFF"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/opencv/opencv/archive/refs/tags/4.13.0.tar.gz",
                    "sha512": "ad677353cc1a4e51f2b9790724890eb65ec7633e0a658d63862767365b83d46e85791d691733e88c0f53d2b7294029c1b1ad8e5509c27d2edba8af7d63ade21e"
                }
            ]
        },
        {
            "name": "libraw",
            "buildsystem": "autotools",
            "config-opts": [
                "--disable-examples"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/LibRaw/LibRaw/archive/refs/tags/0.22.1.tar.gz",
                    "sha512": "123050ea30366ada37b40e0aee84453f71f10a5e5e39261a1d16b96dc395f85a9ecdfd043d51b4c347a67546affdfa7ca84c10fa84d73b9b4070c074f1d301e8"
                },
                {
                    "type": "script",
                    "commands": [
                        "autoreconf --install --symlink"
                    ]
                }

            ]
        },
        {
            "name": "quazip",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DQUAZIP_QT_MAJOR_VERSION=6"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/stachenov/quazip/archive/refs/tags/v1.7.2.tar.gz",
                    "sha512": "423e38def8f93c4c3e7d261227ce0d38f9048d84e2aca029e21b5d0b71915a7ab14d3836a7ed3081cf9f6d3369aaf4eec44ffe2d652cc1a011c211bb940b7e91"
                }
            ]
        },
        {
            "name": "nomacs",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DENABLE_QUAZIP=ON",
                "-DENABLE_TESTING=OFF",
                "-DUSE_SYSTEM_QUAZIP=ON",
                "-DQT_VERSION_MAJOR=6"
            ],
            "subdir": "ImageLounge",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/nomacs/nomacs/archive/refs/tags/3.23.1.tar.gz",
                    "sha512": "5dc2b57bf64cefe99be8c8e4031db9ee9927bf180043d7eeb2c38a5500199e5d4a56826751927044a45ed77d3bd0cb89bfb63b52d90d9d6e23bd9245f6ed7318"
                }
            ]
        }
    ]
}
